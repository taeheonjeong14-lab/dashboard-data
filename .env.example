# 루트 .env — Node 스크립트(index.js, export:ranks, verify:supabase, naver-rank-main.py 가 dotenv 로 읽음)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 순위 매크로 (선택)
# RANK_INPUT_SOURCE=db
# RANK_USE_DEBUG_CHROME=1
# CHROME_DEBUGGING_PORT=9222
# 순위 전용 Chrome 포트(설정 시 우선) — 비로그인 프로필로 띄워두고 격리하면 계정 탐지 리스크 0
# RANK_CHROME_DEBUGGING_PORT=9999

# 네이버 차단 회피 노브 (선택) — 차단이 잦아지면 값을 키우거나 동시성을 낮춘다.
# rank(비로그인) 키워드 사이 랜덤 지연(초). 기본 1.5~4.0
# RANK_DELAY_MIN_SEC=3
# RANK_DELAY_MAX_SEC=7
# rank 내부 병렬 워커 수. 기본 1 (한 IP에 동시 타격 최소)
# RANK_PARALLEL_WORKERS=1
# rank launch 모드 UA — 워커 PC 실제 Chrome 버전에 맞추고 싶을 때만(미설정 시 최신 기본값)
# RANK_USER_AGENT=
# blog/place(로그인) 페이지 이동 사이 랜덤 지연(ms). 미설정 시 스크립트 기본값
# LOGIN_COLLECT_DELAY_MIN_MS=2000
# LOGIN_COLLECT_DELAY_MAX_MS=4000
# 워커 동시성(step-aware). 전체 캡 안에서, 스크래핑(rank/blog/place) 잡만 따로 제한한다.
# searchad(공식 API) 잡은 스크래핑 캡과 무관하게 전체 캡까지 병렬로 돈다.
# 전체 동시 잡 수(스크래핑+API 합산). 기본 3
# COLLECT_MAX_CONCURRENT_JOBS=4
# 스크래핑 잡 동시 실행 캡(같은 IP 동시 타격 제한). 기본 1, 차단 잦으면 1 유지
# SCRAPE_MAX_CONCURRENT=1

# 검색광고(SearchAd) 수집기 (선택)
# SEARCHAD_API_BASE_URL=https://api.searchad.naver.com
# SEARCHAD_METRIC_DATE=2026-04-16
# SEARCHAD_SECRET_PASSPHRASE=YOUR_ENCRYPTION_PASSPHRASE

# 대시보드(Next)는 분리된 dashboard 리포의 .env.local 에 아래 두 개
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
