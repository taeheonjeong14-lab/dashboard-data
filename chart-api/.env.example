# Postgres — chart_pdf / health_report 스키마 raw SQL용 (Pooling URL 권장)
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Storage — PDF 업로드 버킷(대시보드에서 생성). 기본 pdf-uploads
# SUPABASE_PDF_UPLOADS_BUCKET=pdf-uploads

# 케이스 이미지 버킷명 오버라이드 (미설정 시 case-image — 파트너 이관 문서와 동일)
# SUPABASE_IMAGE_CASE_BUCKET=case-image

# 케이스 이미지 업로드 튜닝 (기본 2048 / 82)
# IMAGE_CASE_MAX_EDGE=2048
# IMAGE_CASE_WEBP_QUALITY=82

# 진료 차트 API — Authorization: Bearer <값>
CHART_APP_API_KEY=

# 공유 리뷰 UI 베이스 (POST review-share 응답 shareUrl 조합). 비우면 토큰만 반환.
CHART_APP_SHARE_PUBLIC_BASE_URL=

# LLM (Gemini). 미설정 시 일부 POST 가 503.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# text-bucketing 버킷 JSON 출력 상한 (토큰). 미설정 시 24576, 최소 4096·최대 65536
# GEMINI_TEXT_BUCKETING_MAX_TOKENS=24576

# 블로그 글 검수 (Vercel AI Gateway) — 이 키 하나로 Claude·Grok·Gemini 전부 호출.
#   Anthropic·xAI 별도 계정/키 불필요. Vercel 프로젝트 → AI Gateway 켜고 키 발급해 넣는다.
#   미설정 시 /api/content/blog-review 가 503.
AI_GATEWAY_API_KEY=
# 게이트웨이 base URL 오버라이드 (기본 https://ai-gateway.vercel.sh/v1)
# AI_GATEWAY_BASE_URL=
# 리뷰어 3개 모델 슬러그(쉼표, provider/model, 버전은 점 표기). 미설정 시 아래 비용절감 기본값.
#   게이트웨이 카탈로그 확인: GET /api/debug/blog-review-models (Authorization: Bearer CHART_APP_API_KEY)
# BLOG_REVIEW_MODELS=anthropic/claude-haiku-4.5,xai/grok-4.1-fast-reasoning,google/gemini-2.5-flash
# 집계(취합) 모델 — 지시 준수(개조식·길이) 좋은 haiku 권장
# BLOG_REVIEW_AGGREGATOR_MODEL=anthropic/claude-haiku-4.5

# PDF — 기본은 인프로세스 playwright-core + @sparticuz/chromium (vet-report 와 동일 계열)
# 로컬(Windows 등)에서 시스템 Chrome 경로를 지정하면 편함:
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
#
# 원격 PDF 워커만 쓸 때(설정 시 원격 우선, 미설정 시 위 Chromium 사용):
# PLAYWRIGHT_PDF_SERVICE_URL=
# PLAYWRIGHT_PDF_SERVICE_SECRET=
#
# Vercel Deployment Protection(미리보기 보호 등)일 때 서버리스가 자기 호스트의 /runs/.../print 을 열 수 있게 함 (선택)
# VERCEL_AUTOMATION_BYPASS_SECRET=

# 건강검진 인쇄 (run) — PDF 가 열 URL. vet-report: …/runs/{runId}/report/print
# HEALTH_CHECKUP_PRINT_URL_TEMPLATE=https://vet.example.com/runs/{runId}/report/print
# HEALTH_CHECKUP_PRINT_BASE_URL=
# VET_REPORT_PUBLIC_ORIGIN=https://vet.example.com
# 선택: 오리진만 쓸 때 run 경로 오버라이드 (미설정 시 …/runs/<runId>/report/print)
# VET_REPORT_HEALTH_PRINT_SUBPATH=
#
# 공유 PDF (export-by-share) — 토큰 경로 (runId 아님): …/review/health-checkup/<token>/print
# HEALTH_CHECKUP_SHARE_PRINT_URL_TEMPLATE=https://vet.example.com/review/health-checkup/{token}/print
# VET_REPORT_PUBLIC_ORIGIN 위와 같으면 기본: …/review/health-checkup/<token>/print
# VET_REPORT_HEALTH_SHARE_PRINT_SUBPATH=review/health-checkup

# 표지(1p) 반려동물 이미지 — 병원 무관 공통 고정 URL(권장: Supabase public URL, 만료 없음)
# REPORT_DOG_COVER_URL=https://<project-ref>.supabase.co/storage/v1/object/public/report-assets/dog_cover.png
# REPORT_CAT_COVER_URL=https://<project-ref>.supabase.co/storage/v1/object/public/report-assets/cat_cover.png

# 크론 보호 (선택). 설정 시 Authorization: Bearer 값과 일치해야 함.
CRON_SECRET=

# 카카오 알림톡 (알리고) — 건강검진 리포트 보호자 전송
ALIGO_API_KEY=
ALIGO_USER_ID=
# 발신프로필키(카카오 채널 등록 시 받은 senderkey)
ALIGO_SENDER_KEY=
# 발신번호(알리고 사전등록 전화번호, 숫자만 — 예: 01027475143)
ALIGO_SENDER=
# 알림톡 템플릿 코드 (미설정 시 UI_3996)
# ALIGO_TPL_CODE=UI_3996
# Y 면 실제 발송 안 함(테스트)
# ALIGO_TEST_MODE=N
