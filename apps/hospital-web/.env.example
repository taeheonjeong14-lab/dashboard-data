# Supabase — admin-web과 동일 프로젝트
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# OAuth PKCE / redirect base URL
# local: http://localhost:3010
# production: https://vet-solution-hospital-ui.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# DDx API (AI 진료 보조) — 미설정 시 기본값 https://ddx-api.vercel.app
NEXT_PUBLIC_DDX_API_URL=https://ddx-api.vercel.app

# Chart/PDF extraction API
# CHART_API_URL 미설정 시 기본값 https://chart-api-five.vercel.app
CHART_API_URL=https://chart-api-five.vercel.app
# chart-api 프로젝트의 CHART_APP_API_KEY 와 동일한 값으로 설정 (불일치 시 401 Unauthorized)
CHART_API_KEY=xxx

# Blog preview API
NEXT_PUBLIC_DASHBOARD_API_URL=https://dashboard-api-jade.vercel.app

# 사전문진 알림톡(알리고) 템플릿 코드 — 카카오 심사 통과 후 받은 tpl_code.
# WL 버튼 도메인을 NEXT_PUBLIC_SITE_URL(운영 도메인)/survey 로 등록해야 함.
# (참고용) 실제 코드는 send-kakao/route.ts 에 SURVEY_TEMPLATE_CODE 로 하드코딩(UI_9061). 이 env 는 미사용.
ALIGO_TPL_CODE_SURVEY=UI_9061
# 사전문진 WL 버튼 링크 베이스. 카카오 등록 버튼 도메인과 일치해야 함(미설정 시 https://app.thehamm.kr).
SURVEY_LINK_BASE=https://app.thehamm.kr
