# Supabase (DDx·dashboard-ui와 동일 프로젝트 anon 키)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth PKCE / 리다이렉트 기준 (로컬·프로덕션 각각 Vercel에 설정)
# 로컬: http://localhost:3011
# 프로덕션: https://vet-solution-admin-ui.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3011

# 브라우저 스모크용 dashboard-api 베이스 URL (CORS 허용됨)
NEXT_PUBLIC_DASHBOARD_API_URL=https://dashboard-api-jade.vercel.app

# 통계(/admin/performance)는 admin-web 내부 라우트 + `/api/admin/stats/*` 로 제공합니다. dashboard-ui URL 불필요.

# 서버 전용 — 로그인 후 관리자 여부 판별 시 ddx-api 호출 (브라우저에 노출하지 않음)
# 예: https://ddx-api.vercel.app
DDX_API_BASE_URL=

# 서버 전용 — 병원·차트 업로드 등 레거시 admin-ui DB 작업 (절대 NEXT_PUBLIC 아님)
# 차트 추출 이력 목록(GET /api/admin/data/parse-runs)은 PostgREST(HTTPS)만 사용 — 위 URL·이 키면 충분, 5432 불필요.
SUPABASE_SERVICE_ROLE_KEY=

# 서버 전용 — chart_pdf.* 에 직접 SQL(pg)이 필요한 작업: 삭제·버킷팅 등 (목록 조회는 사용 안 함)
# Supabase: 직접 연결(db.<ref>.supabase.co:5432)이 회사망/VPN에서 막히면 connect ETIMEDOUT 이 납니다.
# Session 풀러도 보통 포트 5432라, 5432 전체가 막히면 여전히 실패할 수 있습니다.
# → 같은 화면의 Transaction 풀러 URI(보통 *.pooler.supabase.com:6543, 사용자 postgres.<ref>)를 DATABASE_URL에 시도.
# Dashboard → Project Settings → Database → Connection string
DATABASE_URL=

# Supabase가 아닌 DB에서 SSL 검증 실패 시에만 1 (기본: DATABASE_URL 호스트가 supabase면 자동으로 ssl 적용)
# PGSSL_INSECURE=1

# PDF 추출용 LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEXT_BUCKETING_MAX_TOKENS=24576

# PDF 업로드 Storage 버킷 (기본: pdf-uploads)
SUPABASE_PDF_UPLOADS_BUCKET=pdf-uploads

# chart-api (건강검진 LLM·인쇄·PDF·외부검토 링크) — admin-web 서버가 Bearer로 프록시
# 반드시 chart-api 프로세스 주소 (로컬 예: http://127.0.0.1:3003). admin-web(3011)·다른 포트와 혼동하지 마세요.
# 예: http://localhost:3003  (chart-api package.json 기본 포트 3003)
# 서버→chart-api fetch 시 hostname localhost 는 자동으로 127.0.0.1 로 바꿔 IPv6(::1) 연결 실패를 줄입니다.
CHART_API_BASE_URL=
CHART_APP_API_KEY=

# (선택) chart-api 배포 보호 우회 — admin「미리보기」새 창 URL에만 붙음. chart-api 쪽과 동일 값.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# (선택) 외부 검토 shareUrl 의 공개 베이스 — chart-api CHART_APP_SHARE_PUBLIC_BASE_URL 과 동일 권장
# CHART_APP_SHARE_PUBLIC_BASE_URL=

# 수집 Worker (배포 환경에서 로컬 PC의 collect-worker.js 로 요청을 프록시)
# 로컬 실행: npm run collect:worker  →  ngrok / Cloudflare Tunnel 로 외부 노출
# 설정 시 스크립트를 직접 스폰하는 대신 이 URL 로 POST /collect/run 을 전달합니다.
# COLLECT_WORKER_URL=https://xxxx.ngrok-free.app
# COLLECT_WORKER_API_KEY=임의의강력한키

# 운영자 에러 알림(텔레그램) — /api/cron/error-alert 가 5분마다 error_logs 새 에러를 다이제스트로 발송
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 알림 본문에 넣을 admin 링크(선택). 예: https://admin.thehamm.kr
ADMIN_WEB_URL=
