{
  "name": "naver-blog-stat",
  "version": "1.0.0",
  "private": true,
  "description": "네이버 블로그 조회수·순방문자 수집 (Chrome 디버깅 모드 연동)",
  "main": "index.js",
  "workspaces": [
    "admin-ui",
    "chart-api",
    "dashboard-api",
    "ddx-api",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node index.js",
    "collect": "node index.js",
    "collect:all": "node scripts/collect-all.js",
    "collect:all:batch": "node scripts/collect-all-batch.js",
    "collect:blog-metrics": "node scripts/collect-blog-metrics.js",
    "collect:smartplace-inflow": "node scripts/collect-smartplace-inflow.js",
    "export:ranks": "node scripts/export-blog-ranks.js",
    "verify:supabase": "node scripts/verify-supabase.js",
    "chrome": "node scripts/launch-chrome-debug.js",
    "collect:searchad": "python scripts/naver-searchad-main.py",
    "collect:googleads": "node scripts/googleads-collect-main.js",
    "auth:googleads": "node scripts/googleads-oauth-token.js",
    "admin:dev": "npm --prefix admin-ui run dev",
    "admin:build": "npm --prefix admin-ui run build",
    "hospital:dev": "npm --prefix apps/hospital-web run dev",
    "hospital:build": "npm --prefix apps/hospital-web run build",
    "admin-web:dev": "npm --prefix apps/admin-web run dev",
    "admin-web:build": "npm --prefix apps/admin-web run build",
    "ddx-api:dev": "npm --prefix ddx-api run dev",
    "ddx-api:build": "npm --prefix ddx-api run build",
    "dashboard-api:dev": "npm --prefix dashboard-api run dev",
    "dashboard-api:build": "npm --prefix dashboard-api run build",
    "chart-api:dev": "npm --prefix chart-api run dev",
    "chart-api:build": "npm --prefix chart-api run build",
    "sql:decode-batch": "node scripts/sql/decode-supabase-batch.mjs",
    "sql:split-inserts": "node scripts/sql/split-staging-inserts-into-batches.mjs",
    "storage:migrate": "node scripts/storage-migrate-supabase.mjs",
    "storage:migrate:dry-run": "node scripts/storage-migrate-supabase.mjs --dry-run",
    "storage:migrate:list": "node scripts/storage-migrate-supabase.mjs --list-only",
    "verify:storage-db-paths": "node scripts/verify-storage-db-paths.mjs"
  },
  "keywords": [
    "naver",
    "blog",
    "statistics",
    "puppeteer",
    "cdp"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "pg": "^8.13.0",
    "dotenv": "^17.2.3",
    "google-ads-api": "^23.0.0",
    "google-auth-library": "^10.6.2",
    "puppeteer-core": "^21.0.0",
    "xlsx": "^0.18.5"
  }
}
