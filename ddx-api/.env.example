# Required for Prisma at runtime
DATABASE_URL=

# Optional: Prisma CLI migrations (if used)
# DIRECT_URL=

# Supabase (BACKEND_HANDOFF §2.2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (emails, webhooks)
NEXT_PUBLIC_APP_URL=
# VERCEL_URL=   # set automatically on Vercel

# Admin — 쉼표 구분 이메일. vet-solution-admin-ui 인가 시 `/api/admin/check`에서 사용.
# `core.users.role = 'admin'` 이면 동일 API에서 이미 허용(ADMIN_EMAILS 없어도 됨).
ADMIN_EMAILS=

# AI (BACKEND_HANDOFF §2.3–2.4)
NEXT_PUBLIC_GEMINI_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=

# Cron
CRON_SECRET=
