# Required for Prisma at runtime
DATABASE_URL=

# Optional: Prisma CLI migrations (if used)
# DIRECT_URL=

# Supabase (BACKEND_HANDOFF §2.2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (emails, webhooks)
NEXT_PUBLIC_APP_URL=
# VERCEL_URL=   # set automatically on Vercel

# Admin — 내부 관리자는 DB `core.admin_users`(id = Auth uid)가 단일 진실원.
# 마이그레이션/비상용: 쉼표 구분 이메일 또는 레거시 `core.users.role = 'admin'`.
ADMIN_EMAILS=

# AI (BACKEND_HANDOFF §2.3–2.4)
NEXT_PUBLIC_GEMINI_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=

# Cron
CRON_SECRET=
